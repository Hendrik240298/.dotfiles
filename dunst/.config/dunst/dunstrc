[global]
    monitor = 0
    follow = keyboard
    width = 360
    height = 200
    origin = top-right
    offset = 16x34
    scale = 0
    notification_limit = 8
    progress_bar = false
    padding = 12
    horizontal_padding = 12
    text_icon_padding = 10
    separator_height = 2
    frame_width = 2
    corner_radius = 0
    transparency = 0
    gap_size = 6
    font = JetBrainsMono Nerd Font 10
    line_height = 0
    markup = full
    format = <b>%s</b>\n%b
    alignment = left
    vertical_alignment = center
    icon_position = left
    min_icon_size = 16
    max_icon_size = 32
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#1a1b26"
    foreground = "#c0caf5"
    frame_color = "#24283b"
    timeout = 4

[urgency_normal]
    background = "#1a1b26"
    foreground = "#c0caf5"
    frame_color = "#7aa2f7"
    timeout = 6

[urgency_critical]
    background = "#1a1b26"
    foreground = "#c0caf5"
    frame_color = "#f7768e"
    timeout = 0
